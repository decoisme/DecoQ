# ============================================================
# QRIS Verifier - Environment Variables
# Salin file ini menjadi .env.local dan isi nilainya
# ============================================================

# Supabase Configuration
# Dapatkan dari: https://app.supabase.com > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Admin Credentials (Role-Based Access Control)
# Admin: View only access (dapat melihat database saja)
ADMIN_KEY=admin123

# Superadmin: Full access (dapat manipulasi database)
SUPERADMIN_KEY=superadmin123

# Legacy Admin Secret (untuk backward compatibility dengan /admin lama)
ADMIN_SECRET=admin123

# ============================================================
# PENTING: 
# 1. Jangan commit file .env.local ke repository!
# 2. Ganti semua default keys dengan password yang kuat di production!
# 3. File .env.example ini aman untuk di-commit.
# ============================================================
