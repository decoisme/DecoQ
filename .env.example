# ============================================================
# QRIS Verifier - Environment Variables
# Salin file ini menjadi .env.local dan isi nilainya
# ============================================================

# Supabase Configuration
# Dapatkan dari: https://app.supabase.com > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Site URL (untuk email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin Credentials (Role-Based Access Control)
# Admin: View only access (dapat melihat database saja)
ADMIN_KEY=admin123

# Superadmin: Full access (dapat manipulasi database)
SUPERADMIN_KEY=superadmin123

# Legacy Admin Secret (untuk backward compatibility dengan /admin lama)
ADMIN_SECRET=admin123

# ============================================================
# Email Configuration (Nodemailer)
# ============================================================

# Set to 'true' to use Nodemailer instead of Supabase Auth emails
USE_NODEMAILER=false

# SMTP Configuration
# For Gmail: smtp.gmail.com, port 587
# For Outlook: smtp-mail.outlook.com, port 587
# For custom SMTP: your-smtp-server.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=DecoQ <your-email@gmail.com>

# ============================================================
# Gmail Setup Instructions:
# 1. Enable 2-Factor Authentication di Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use App Password sebagai EMAIL_PASSWORD (bukan password Gmail biasa)
# ============================================================

# ============================================================
# PENTING: 
# 1. Jangan commit file .env.local ke repository!
# 2. Ganti semua default keys dengan password yang kuat di production!
# 3. File .env.example ini aman untuk di-commit.
# ============================================================
